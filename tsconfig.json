{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["ES2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "skipLibCheck": true,
    "noEmit": true,
    "strict": false,
    "esModuleInterop": true
  },
  "include": ["api/**/*.ts", "middleware.ts"]
}
