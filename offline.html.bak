<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Connection Lost | Life Gym Coach Portal</title>
  <style>
    :root {
      --bg-color: #05050b;
      --card-bg: rgba(18, 22, 36, 0.6);
      --card-border: rgba(255, 255, 255, 0.05);
      --text-main: #f3f4f6;
      --text-muted: #9ca3af;
      --accent: #3b82f6;
      --accent-glow: rgba(59, 130, 246, 0.15);
      --accent-hover: #2563eb;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background-color: var(--bg-color);
      color: var(--text-main);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
    }

    /* Branded glowing ambient backgrounds */
    .glow-1 {
      position: absolute;
      top: -10%;
      left: -10%;
      width: 40vw;
      height: 40vw;
      background: rgba(59, 130, 246, 0.08);
      border-radius: 50%;
      filter: blur(120px);
      pointer-events: none;
    }

    .glow-2 {
      position: absolute;
      bottom: -10%;
      right: -10%;
      width: 40vw;
      height: 40vw;
      background: rgba(99, 102, 241, 0.05);
      border-radius: 50%;
      filter: blur(120px);
      pointer-events: none;
    }

    .container {
      position: relative;
      z-index: 10;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-radius: 24px;
      padding: 48px;
      width: 90%;
      max-width: 480px;
      text-align: center;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.05);
      animation: fadeIn 0.6s ease-out;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(12px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Offline Icon Design */
    .icon-container {
      width: 80px;
      height: 80px;
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.2);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 28px;
      position: relative;
      box-shadow: 0 0 20px rgba(239, 68, 68, 0.05);
    }

    .icon-container::after {
      content: '';
      position: absolute;
      inset: -4px;
      border-radius: 50%;
      border: 1px solid rgba(239, 68, 68, 0.1);
      animation: pulse 2s infinite ease-in-out;
    }

    @keyframes pulse {
      0% {
        transform: scale(1);
        opacity: 1;
      }
      100% {
        transform: scale(1.15);
        opacity: 0;
      }
    }

    .icon-container svg {
      width: 36px;
      height: 36px;
      color: #ef4444;
    }

    h1 {
      font-size: 24px;
      font-weight: 800;
      margin-bottom: 12px;
      letter-spacing: -0.025em;
    }

    p {
      color: var(--text-muted);
      font-size: 14px;
      line-height: 1.6;
      margin-bottom: 32px;
      font-weight: 500;
    }

    .retry-btn {
      background: linear-gradient(135deg, #2563eb, #4f46e5);
      color: #ffffff;
      border: none;
      border-radius: 14px;
      padding: 14px 28px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      width: 100%;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 4px 12px rgba(59, 130, 246, 0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .retry-btn:hover {
      background: linear-gradient(135deg, #1d4ed8, #4338ca);
      transform: translateY(-1px);
      box-shadow: 0 6px 16px rgba(59, 130, 246, 0.3);
    }

    .retry-btn:active {
      transform: translateY(1px);
      box-shadow: 0 2px 6px rgba(59, 130, 246, 0.2);
    }

    .retry-btn svg {
      width: 16px;
      height: 16px;
      animation: spin 3s linear infinite paused;
    }

    .retry-btn.loading svg {
      animation-play-state: running;
    }

    @keyframes spin {
      100% {
        transform: rotate(360deg);
      }
    }
  </style>
</head>
<body>
  <div class="glow-1"></div>
  <div class="glow-2"></div>

  <div class="container">
    <div class="icon-container">
      <!-- Wi-Fi Off Icon -->
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M1 1l22 22M16.72 11.06A10.94 10.94 0 0119 12.5M5 12.5a10.94 10.94 0 015.83-2.84M8.57 16.38a7.07 7.07 0 012.38-.81M21 8.5a15.66 15.66 0 00-5.18-1.78M3 8.5C5.7 6.95 8.9 6 12 6c1.09 0 2.18.12 3.25.35M12 20h.01" />
      </svg>
    </div>
    <h1>Connection Lost</h1>
    <p>Please check your internet connection. We couldn't reach the server. Make sure you are connected to Wi-Fi or mobile data and try again.</p>
    <button class="retry-btn" id="retry-btn" onclick="handleRetry()">
      <!-- Refresh/Sync Icon -->
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3" />
      </svg>
      <span id="btn-text">Try Reconnecting</span>
    </button>
  </div>

  <script>
    function handleRetry() {
      const btn = document.getElementById('retry-btn');
      const text = document.getElementById('btn-text');
      
      btn.classList.add('loading');
      text.innerText = 'Retrying Connection...';
      
      // Parse retry url from location search params or default
      const params = new URLSearchParams(window.location.search);
      const targetUrl = params.get('url') || 'https://gym-kappa-three.vercel.app';
      
      // Wait a short moment to show animation before redirecting
      setTimeout(() => {
        window.location.href = targetUrl;
      }, 800);
    }
  </script>
</body>
</html>
