{
  "name": "athlete-dashboard",
  "private": true,
  "version": "0.0.8",
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "electron:package": "electron-builder build --win",
    "test:bot": "node scratch/test_bot.cjs",
    "test:load": "node scratch/load_test_native.cjs"
  },
  "dependencies": {
    "@google/genai": "^2.2.0",
    "@supabase/supabase-js": "^2.105.4",
    "@types/leaflet": "^1.9.21",
    "@upstash/ratelimit": "^2.0.8",
    "@vercel/analytics": "^2.0.1",
    "@vercel/functions": "^3.6.2",
    "@vercel/kv": "^3.0.0",
    "@vercel/speed-insights": "^2.0.0",
    "csv-parser": "^3.2.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.14.0",
    "nodemailer": "^8.0.10",
    "pdfkit": "^0.19.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@napi-rs/canvas": "^1.0.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.14",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^3.4.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.lifegym.coachportal",
    "productName": "Life Gym Coach Portal",
    "directories": {
      "output": "dist_desktop"
    },
    "files": [
      "electron.cjs",
      "preload.cjs",
      "offline.html",
      "app_icon_rounded.png",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "app_icon_rounded.png",
      "artifactName": "Life-Gym-Coach-Portal-Setup.exe"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Life Gym Coach"
    }
  }
}
