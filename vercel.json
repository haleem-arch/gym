{
  "headers": [
    {
      "source": "/ultimate-coach-blueprint.pdf",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "inline; filename=\"ultimate-coach-blueprint.pdf\""
        },
        {
          "key": "Content-Type",
          "value": "application/pdf"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/)[^.]*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-deactivate-expired",
      "schedule": "0 0 * * *"
    }
  ]
}
